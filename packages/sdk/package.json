{
  "name": "@ngx-copilot/sdk",
  "version": "0.1.0",
  "description": "Reusable Angular SDK for embedding AI copilot shells, context providers, RAG citations, tool timelines, and approval workflows into enterprise applications.",
  "keywords": [
    "angular",
    "copilot",
    "ai",
    "llm",
    "rag",
    "tool-calling",
    "approvals",
    "streaming",
    "enterprise",
    "sdk",
    "mcp",
    "agent"
  ],
  "author": {
    "name": "Ankit Parekh",
    "url": "https://github.com/AnkitParekh007"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnkitParekh007/ngx-copilot-platform.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/AnkitParekh007/ngx-copilot-platform/issues"
  },
  "homepage": "https://ankitparekh007.github.io/ngx-copilot-platform/",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "tslib": "^2.6.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "ng build @ngx-copilot/sdk",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.spec.ts tests/components/**/*.spec.ts",
    "test:components": "node --import tsx --test --test-concurrency=1 tests/components/**/*.spec.ts",
    "lint": "ng lint @ngx-copilot/sdk",
    "pack": "npm pack",
    "pack:dry": "npm publish --dry-run"
  }
}
