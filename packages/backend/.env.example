# =============================================================================
# ngx-copilot-platform — Backend Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# =============================================================================

# --- Supabase (Vector Store + Database) ---
# Get these from https://app.supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (Rate Limiting) ---
# Get these from https://console.upstash.com
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your-upstash-token

# --- Copilot API Keys ---
# Comma-separated cpk_ prefixed keys issued by the admin UI
COPILOT_API_KEYS=cpk_dev_your_key_here,cpk_prod_your_key_here
# Master key for admin operations (admin UI only)
COPILOT_MASTER_API_KEY=cpk_master_your_key_here

# --- CORS ---
# Comma-separated origins allowed to call the API
# Default (if unset): http://localhost:4200, http://localhost:4201
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201

# --- OpenAI (Embeddings + LLM) ---
OPENAI_API_KEY=sk-your-openai-key

# --- GitHub Ingestion (optional) ---
# Personal access token or app token with repo:read scope
GITHUB_TOKEN=ghp_your_github_token

# --- Bitbucket Ingestion (optional) ---
BITBUCKET_USERNAME=your-bitbucket-username
BITBUCKET_APP_PASSWORD=your-bitbucket-app-password

# --- Browser Agent (Playwright, optional) ---
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
