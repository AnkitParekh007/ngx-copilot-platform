# Base URL of the ngx-copilot-platform backend (packages/backend)
# When running locally: http://localhost:3001
# When deployed: your Vercel backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Admin API key (cpk_master_ prefixed) to authenticate admin UI calls
NEXT_PUBLIC_ADMIN_API_KEY=cpk_master_your_key_here
