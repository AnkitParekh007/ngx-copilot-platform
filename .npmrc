# Hoist Angular peer deps and rxjs so that the pre-built SDK bundle at dist/sdk/fesm2022/
# can resolve its imports when consumed via a pnpm workspace symlink.
# Without hoisting, esbuild walks up from the real path of the symlink target (dist/sdk/)
# and cannot find @angular/* or rxjs in pnpm's isolated virtual store.
public-hoist-pattern[]=@angular/*
public-hoist-pattern[]=rxjs
public-hoist-pattern[]=tslib
public-hoist-pattern[]=zone.js
